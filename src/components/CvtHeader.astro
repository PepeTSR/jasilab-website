---
import { cvtAppUrl, getCvtHeaderCta, getCvtNav, type CvtNavItem } from "../lib/nav";
import { cvtHomeHref, isActiveCvtNav, isCvtRootSite } from "../lib/site";
import { isSuperhumanTheme, isTeslaTheme, isProductTheme } from "../lib/cvt-theme";
import ShDarkModeToggle from "./cvt-shell/ShDarkModeToggle.astro";

const current = Astro.url.pathname;
const cvtNav = getCvtNav(current);
const headerCta = getCvtHeaderCta(current);
const homeHref = cvtHomeHref();
const isHome =
  current === "/" ||
  current === homeHref ||
  current === "/cvt" ||
  current === "/cvt/";
const heroNav = isTeslaTheme && isHome;
const lightNav = isSuperhumanTheme && !isHome;

function navLinkProps(item: CvtNavItem) {
  if (item.external) {
    return { href: item.href, target: "_blank", rel: "noopener" };
  }
  return { href: item.href };
}

function ctaLinkProps(cta: { href: string; external?: boolean }) {
  if (cta.external !== false) {
    return { href: cta.href, target: "_blank", rel: "noopener" };
  }
  return { href: cta.href };
}
---

<header
  class:list={[
    "nav-bar sticky top-0 z-50",
    isSuperhumanTheme && (lightNav ? "nav-bar--light" : "nav-bar--dark"),
    heroNav && "nav-bar--hero",
  ]}
>
  <div
    class:list={[
      "mx-auto max-w-6xl px-4 py-3 sm:px-8",
      isSuperhumanTheme
        ? "sh-header-bar"
        : "flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between",
    ]}
  >
    {isCvtRootSite ? (
      <a href={homeHref} class="group flex flex-col gap-0.5">
        {isSuperhumanTheme ? (
          <span class="sh-wordmark">CVT</span>
        ) : isTeslaTheme ? (
          <span class="tesla-wordmark">CVT</span>
        ) : (
          <>
            <span class="text-lg font-semibold tracking-tight text-ink-strong group-hover:text-primary-soft">CVT</span>
            <span class="eyebrow-mono !text-[10px] !leading-tight !text-mute">Connected Verification Terminal</span>
          </>
        )}
      </a>
    ) : (
      <div class="flex items-center gap-3">
        <a href="/" class="eyebrow-mono !text-mute hover:text-body">JasiLab</a>
        <span class="text-hairline">/</span>
        <a href={homeHref} class="text-lg font-semibold text-ink-strong">CVT</a>
      </div>
    )}

    <nav class="flex flex-wrap gap-1">
      {cvtNav.map((item) => (
        <a
          {...navLinkProps(item)}
          class:list={[
            item.external ? "nav-link" : isActiveCvtNav(current, item.href, homeHref) ? "nav-link-active" : "nav-link",
            item.external && !heroNav && "text-primary-deep",
          ]}
        >
          {item.label}{item.external ? " ↗" : ""}
        </a>
      ))}
    </nav>

    {isCvtRootSite ? (
      <div class:list={["flex shrink-0 items-center gap-2", isSuperhumanTheme && "sh-header-bar__cta"]}>
        {isSuperhumanTheme && <ShDarkModeToggle />}
        <div class="hidden gap-2 sm:flex">
        {isProductTheme ? (
          <a {...ctaLinkProps(headerCta)} class="btn-primary !py-2 !text-sm">
            {headerCta.label}
          </a>
        ) : (
          <>
            <a {...ctaLinkProps(headerCta)} class="btn-primary !py-2 !text-sm">
              {headerCta.label}
            </a>
            <a href={cvtAppUrl} target="_blank" rel="noopener" class="btn-outline !py-2 !text-sm">
              Registry ↗
            </a>
          </>
        )}
        </div>
      </div>
    ) : (
      <a href={cvtAppUrl} target="_blank" rel="noopener" class="btn-outline hidden shrink-0 !py-2 !text-sm sm:inline-flex">
        Open registry ↗
      </a>
    )}
  </div>
</header>
