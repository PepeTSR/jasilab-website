---
import { cvtNav, cvtAppUrl } from "../lib/nav";
const current = Astro.url.pathname;
---

<header class="border-b border-white/10 bg-slate-950/95 backdrop-blur">
  <div class="mx-auto flex max-w-6xl flex-col gap-3 px-4 py-4 sm:flex-row sm:items-center sm:justify-between sm:px-6">
    <div class="flex items-center gap-4">
      <a href="/" class="text-xs font-medium uppercase tracking-widest text-slate-500 hover:text-slate-300">JasiLab</a>
      <span class="text-slate-700">/</span>
      <a href="/cvt" class="font-display text-lg font-semibold text-white">CVT</a>
    </div>
    <nav class="flex flex-wrap gap-1">
      {cvtNav.map((item) => (
        <a
          href={item.href}
          class:list={[
            "rounded-md px-3 py-1.5 text-sm transition",
            current === item.href
              ? "bg-teal-900/50 text-teal-200"
              : "text-slate-400 hover:bg-white/5 hover:text-white",
          ]}
        >
          {item.label}
        </a>
      ))}
    </nav>
    <a
      href={cvtAppUrl}
      target="_blank"
      rel="noopener"
      class="hidden shrink-0 rounded-full border border-teal-700/50 bg-teal-900/30 px-4 py-1.5 text-sm font-medium text-teal-200 hover:bg-teal-900/50 sm:inline-block"
    >
      Open app ↗
    </a>
  </div>
</header>

<style>
  .font-display { font-family: "Fraunces", Georgia, serif; }
</style>
