---
import { getCvtNav, cvtAppUrl } from "../lib/nav";
import { cvtHomeHref, isActiveCvtNav, isCvtRootSite, jasilabUrl } from "../lib/site";

const current = Astro.url.pathname;
const cvtNav = getCvtNav();
const homeHref = cvtHomeHref();
---

<header class="nav-bar sticky top-0 z-50">
  <div class="mx-auto flex max-w-6xl flex-col gap-3 px-4 py-3 sm:flex-row sm:items-center sm:justify-between sm:px-8">
    <div class="flex items-center gap-3">
      <a href={isCvtRootSite ? jasilabUrl : "/"} class="eyebrow-mono !text-mute hover:text-body">JasiLab</a>
      <span class="text-hairline">/</span>
      <a href={homeHref} class="text-lg font-semibold text-ink-strong">CVT</a>
    </div>
    <nav class="flex flex-wrap gap-1">
      {cvtNav.map((item) => (
        <a
          href={item.href}
          class:list={[
            isActiveCvtNav(current, item.href, homeHref) ? "nav-link-active" : "nav-link",
          ]}
        >
          {item.label}
        </a>
      ))}
    </nav>
    <a href={cvtAppUrl} target="_blank" rel="noopener" class="btn-outline hidden shrink-0 !py-2 !text-sm sm:inline-flex">
      Open app ↗
    </a>
  </div>
</header>
