---
import { cvtWhatsAppPhone, cvtWhatsAppUrl } from "../../lib/nav";
import { cvtLiveLabel } from "../../lib/cvt-narrative";

interface Props {
  compact?: boolean;
}

const { compact = false } = Astro.props;

const qrSrc = `https://api.qrserver.com/v1/create-qr-code/?size=220x220&margin=1&color=00-d992&bgcolor=101010&data=${encodeURIComponent(cvtWhatsAppUrl)}`;
---

<div
  class:list={[
    "flex flex-col items-center rounded-md border border-hairline bg-canvas-soft text-center",
    compact ? "gap-2 p-4" : "gap-3 p-6",
  ]}
>
  <p class="eyebrow-mono !text-[10px] !tracking-widest text-mute">{cvtLiveLabel}</p>
  <a href={cvtWhatsAppUrl} target="_blank" rel="noopener" class="block rounded-sm bg-canvas p-2">
    <img
      src={qrSrc}
      width="220"
      height="220"
      alt="Scan to open CVT plate lookup on WhatsApp"
      class="h-auto w-[min(220px,100%)]"
      loading="eager"
    />
  </a>
  <p class:list={["text-mute", compact ? "text-xs" : "text-sm"]}>Scan to verify a plate on WhatsApp</p>
  <p class="text-xs text-body">{cvtWhatsAppPhone}</p>
</div>
