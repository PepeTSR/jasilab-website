---
import { getCvtExploreLinks } from "../../lib/nav";
import { cvtContactEmail } from "../../lib/site";
const exploreLinks = getCvtExploreLinks();
---

<section class="section-band section-divider border-t border-hairline">
  <p class="map-kicker">Explore</p>
  <h2 class="map-heading">Go deeper</h2>
  <p class="map-lead">
    Vision, roadmap, concepts and guides. Detailed technical specifications are available to partners under agreement.
  </p>

  <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
    {exploreLinks.map((link) => (
      <a href={link.href} class="card-feature group block">
        <p class="font-semibold text-ink-strong group-hover:text-primary-soft">{link.label}</p>
        <p class="mt-1 text-sm text-mute">{link.desc}</p>
      </a>
    ))}
  </div>

  <p class="mt-10 text-center text-sm text-mute">
    Partner or insurer enquiries: <a href={`mailto:${cvtContactEmail}`} class="text-primary-deep hover:text-primary">{cvtContactEmail}</a>
  </p>
</section>
