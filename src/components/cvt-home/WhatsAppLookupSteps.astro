---
import WhatsAppQr from "./WhatsAppQr.astro";

const steps = [
  { title: "Take photo", desc: "Photograph the number plate" },
  { title: "Send on WhatsApp", desc: "Message CVT with the photo" },
  { title: "Get verification", desc: "Receive status and vehicle details" },
  { title: "Grow the network", desc: "Every lookup expands coverage" },
];
---

<div class="mt-10 grid gap-8 lg:grid-cols-[minmax(220px,260px)_1fr] lg:items-start">
  <WhatsAppQr compact />

  <div class="grid gap-4 sm:grid-cols-2">
    {steps.map((step, i) => (
      <div class="card-feature">
        <p class="code-chip w-fit">{String(i + 1).padStart(2, "0")}</p>
        <h3 class="mt-3 font-semibold text-ink-strong">{step.title}</h3>
        <p class="mt-1 text-sm text-body">{step.desc}</p>
      </div>
    ))}
  </div>
</div>
