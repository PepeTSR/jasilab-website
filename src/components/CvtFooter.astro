---
import { cvtAppHostname, cvtAppUrl, cvtWhatsAppUrl, getCvtFooterNav, getCvtNav, getCvtPrimaryCta } from "../lib/nav";
import { cvtContactEmail, cvtMarketingUrl, isCvtRootSite, jasilabUrl } from "../lib/site";
import { cvtPlatformTagline } from "../lib/cvt-narrative";
import { isProductTheme, isSuperhumanTheme } from "../lib/cvt-theme";

const nav = getCvtNav(Astro.url.pathname).filter((item) => item.label !== "Home");
const platformLinks = nav.slice(0, 4);
const resourceLinks = nav.slice(4);

const primaryCta = getCvtPrimaryCta(Astro.url.pathname);
const mainNav = getCvtNav(Astro.url.pathname).filter((item) => item.label !== "Home" && item.label !== primaryCta.label);
const footerNav = getCvtFooterNav();
---

<footer class="border-t border-hairline bg-canvas-soft/20">
  <div class="mx-auto max-w-6xl px-4 py-12 sm:px-8">
    {isCvtRootSite ? (
      <div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-4">
        <div class="lg:col-span-1">
          <p class="text-lg font-semibold text-ink-strong">CVT</p>
          <p class="mt-1 text-sm text-mute">Connected Verification Terminal</p>
          <p class="mt-2 text-sm text-primary-soft">{cvtPlatformTagline}</p>
          <p class="mt-4 text-sm text-body">
            Portable trust for service providers — live in Kampala commercial transport.
          </p>
        </div>

        <div>
          <p class="eyebrow-mono mb-3">Product</p>
          <ul class="space-y-2 text-sm">
            {mainNav.map((item) => (
              <li>
                <a
                  href={item.href}
                  class="text-body hover:text-primary-soft"
                  target={item.external ? "_blank" : undefined}
                  rel={item.external ? "noopener" : undefined}
                >
                  {item.label}{item.external ? " ↗" : ""}
                </a>
              </li>
            ))}
            {isProductTheme && (
              <li>
                <a href={primaryCta.href} class="text-body hover:text-primary-soft" target="_blank" rel="noopener">
                  {primaryCta.label} ↗
                </a>
              </li>
            )}
            <li>
              <a href={cvtWhatsAppUrl} class="text-body hover:text-primary-soft" target="_blank" rel="noopener">
                WhatsApp lookup ↗
              </a>
            </li>
          </ul>
        </div>

        <div>
          <p class="eyebrow-mono mb-3">More</p>
          <ul class="space-y-2 text-sm">
            {footerNav.map((item) => (
              <li>
                <a
                  href={item.href}
                  class="text-body hover:text-primary-soft"
                  target={item.external ? "_blank" : undefined}
                  rel={item.external ? "noopener" : undefined}
                >
                  {item.label}{item.external ? " ↗" : ""}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <div>
          <p class="eyebrow-mono mb-3">Contact</p>
          <ul class="space-y-2 text-sm text-body">
            <li>
              <a href={`mailto:${cvtContactEmail}`} class="hover:text-primary-soft">{cvtContactEmail}</a>
            </li>
            <li>
              <a href={cvtAppUrl} class="hover:text-primary-soft" target="_blank" rel="noopener">
                {cvtAppHostname} ↗
              </a>
            </li>
          </ul>
        </div>
      </div>
    ) : (
      <div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-4">
        <div class="lg:col-span-1">
          <p class="text-lg font-semibold text-ink-strong">CVT</p>
          <p class="mt-1 text-sm text-mute">Connected Verification Terminal</p>
          <p class="mt-2 text-sm text-primary-soft">{cvtPlatformTagline}</p>
        </div>

        <div>
          <p class="eyebrow-mono mb-3">Platform</p>
          <ul class="space-y-2 text-sm">
            {platformLinks.map((item) => (
              <li>
                <a href={item.href} class="text-body hover:text-primary-soft">{item.label}</a>
              </li>
            ))}
          </ul>
        </div>

        <div>
          <p class="eyebrow-mono mb-3">Resources</p>
          <ul class="space-y-2 text-sm">
            {resourceLinks.map((item) => (
              <li>
                <a href={item.href} class="text-body hover:text-primary-soft">{item.label}</a>
              </li>
            ))}
            <li>
              <a href={cvtAppUrl} class="text-body hover:text-primary-soft" target="_blank" rel="noopener">
                Live registry ↗
              </a>
            </li>
          </ul>
        </div>

        <div>
          <p class="eyebrow-mono mb-3">Contact</p>
          <ul class="space-y-2 text-sm text-body">
            <li>
              <a href={`mailto:${cvtContactEmail}`} class="hover:text-primary-soft">{cvtContactEmail}</a>
            </li>
            <li>Partners & insurers welcome</li>
          </ul>
        </div>
      </div>
    )}

    <div class="mt-10 border-t border-hairline pt-6 text-center text-xs text-mute">
      {isCvtRootSite ? (
        <p>© {new Date().getFullYear()} CVT · Created by <a href={jasilabUrl} class="text-body hover:text-primary-soft">JasiLab</a></p>
      ) : (
        <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between sm:text-left">
          <p>© {new Date().getFullYear()} CVT · Built by <a href={jasilabUrl} class="text-body hover:text-primary-soft">JasiLab</a></p>
          <p>
            Product home at{" "}
            <a href={cvtMarketingUrl} class="text-body hover:text-primary-soft">cvt.co.ug</a>
          </p>
        </div>
      )}
    </div>
  </div>
</footer>
