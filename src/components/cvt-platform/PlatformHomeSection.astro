---
import { cvtAppUrl, cvtPath } from "../../lib/site";
import { cvtPlatformStatement, getFeaturedProducts, platformLayers } from "../../lib/cvt-products";
import ProductGrid from "./ProductGrid.astro";

const appHost = cvtAppUrl.replace("https://", "");
---

<section id="platform" class="sh-section sh-section--soft scroll-mt-20">
  <div class="sh-section__inner">
    <p class="sh-eyebrow">The CVT Platform</p>
    <h2 class="sh-display-xl">One infrastructure, many products</h2>
    <p class="sh-lead">{cvtPlatformStatement}</p>
    <p class="sh-lead sh-lead--sm">
      Live app — registration, lookup and registry — at{" "}
      <a href={cvtAppUrl} target="_blank" rel="noopener" class="font-semibold underline underline-offset-2">{appHost} ↗</a>.
    </p>

    <div class="cvt-platform-stack" aria-hidden="true">
      <div class="cvt-platform-stack__layer cvt-platform-stack__layer--top">CVT Platform</div>
      <div class="cvt-platform-stack__row">
        {platformLayers.map((l) => (
          <span class="cvt-platform-stack__chip">{l.label}</span>
        ))}
      </div>
      <div class="cvt-platform-stack__layer">Trust Profiles</div>
    </div>

    <h3 class="sh-display-md mt-12">Live products</h3>
    <p class="sh-lead sh-lead--sm">Already delivering value in Kampala commercial transport.</p>
    <ProductGrid products={getFeaturedProducts()} compact />
  </div>
</section>

<section class="sh-section scroll-mt-20">
  <div class="sh-section__inner sh-section__inner--center">
    <h2 class="sh-display-md">Explore the full platform</h2>
    <p class="sh-lead sh-lead--sm">
      Verify is the hero product today. Everything else extends the same trust layer — with clear maturity at each stage.
    </p>
    <a href={cvtPath("platform")} class="btn-primary mt-8">All platform products →</a>
  </div>
</section>
