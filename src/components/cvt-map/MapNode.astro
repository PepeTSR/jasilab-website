---
/** Reusable node for CVT map diagrams */
interface Props {
  label: string;
  sub?: string;
  href?: string;
  variant?: "default" | "hub" | "highlight" | "future" | "done";
  class?: string;
}

const { label, sub, href, variant = "default", class: className = "" } = Astro.props;

const variants = {
  default: "border-white/15 bg-white/5 text-slate-200",
  hub: "border-teal-500/50 bg-teal-950/60 text-white shadow-lg shadow-teal-900/30",
  highlight: "border-amber-500/40 bg-amber-950/30 text-amber-100",
  future: "border-white/10 bg-white/[0.02] text-slate-500 border-dashed",
  done: "border-teal-600/40 bg-teal-950/40 text-teal-100",
};

const Tag = href ? "a" : "div";
---

<Tag
  href={href}
  class:list={[
    "map-node block rounded-xl border px-4 py-3 text-center transition",
    variants[variant],
    href && "hover:border-teal-500/50 hover:bg-white/10",
    className,
  ]}
>
  <span class="block text-sm font-semibold tracking-wide">{label}</span>
  {sub && <span class="mt-0.5 block text-xs opacity-70">{sub}</span>}
</Tag>
