---
const phases = [
  {
    label: "Today",
    color: "teal",
    items: [
      { title: "WhatsApp Lookup", done: true },
      { title: "Vehicle Verification", done: true },
      { title: "Crowdsourced Reports", done: true },
    ],
  },
  {
    label: "Next",
    color: "amber",
    items: [
      { title: "Trust Passport", done: true, href: "/cvt/guides/building-a-trust-passport" },
      { title: "Good Standing", done: true, href: "/cvt/concepts/good-standing" },
      { title: "Insurance History", done: true, href: "/cvt/guides/insurance" },
      { title: "Skills", done: false },
    ],
  },
  {
    label: "Future",
    color: "slate",
    items: [
      { title: "Employment", href: "/cvt/guides/employment" },
      { title: "Insurance APIs", href: "/cvt/guides/partner-integration" },
      { title: "Finance", href: "/cvt/guides/consent-framework" },
      { title: "Partner APIs", href: "/cvt/guides/partner-integration" },
    ],
  },
];

const timeline = [
  {
    year: "2025",
    items: [
      { label: "WhatsApp plate lookup", done: true },
      { label: "Verification database", done: true },
      { label: "Reporting system", done: true },
    ],
  },
  {
    year: "2026",
    items: [
      { label: "Trust Passport", done: true },
      { label: "Timeline", done: true },
      { label: "Good Standing", done: true },
      { label: "Skills profile", done: false },
    ],
  },
  {
    year: "2027",
    items: [
      { label: "Employer integrations", done: false },
      { label: "Insurance APIs", done: false },
      { label: "Fleet onboarding", done: false },
    ],
  },
  {
    year: "2028+",
    items: [
      { label: "Financing decision support", done: false },
      { label: "Cross-category identity", done: false },
      { label: "Regional expansion", done: false },
    ],
  },
];
---

<section class="map-section" id="roadmap">
  <p class="map-kicker">Evolution</p>
  <h2 class="map-heading">From lookup to opportunity network</h2>

  <div class="mt-10 grid gap-8 lg:grid-cols-3">
    {phases.map((phase) => (
      <div class="rounded-2xl border border-white/10 bg-slate-900/30 p-6">
        <p class:list={[
          "text-xs font-bold uppercase tracking-widest",
          phase.color === "teal" && "text-teal-400",
          phase.color === "amber" && "text-amber-400",
          phase.color === "slate" && "text-slate-400",
        ]}>{phase.label}</p>
        <ul class="mt-4 space-y-2">
          {phase.items.map((item) => (
            <li>
              {item.href ? (
                <a href={item.href} class="flex items-center gap-2 text-sm text-slate-300 hover:text-teal-300">
                  {"done" in item && item.done && <span class="text-teal-500">✓</span>}
                  {"done" in item && !item.done && <span class="text-amber-500/70">◐</span>}
                  {!('done' in item) && <span class="text-slate-600">○</span>}
                  {item.title}
                </a>
              ) : (
                <span class="flex items-center gap-2 text-sm text-slate-400">
                  {item.done ? <span class="text-teal-500">✓</span> : <span class="text-slate-600">○</span>}
                  {item.title}
                </span>
              )}
            </li>
          ))}
        </ul>
      </div>
    ))}
  </div>

  <div class="mt-16">
    <h3 class="map-heading text-xl">Roadmap timeline</h3>
    <div class="timeline mt-8 space-y-0">
      {timeline.map((block, i) => (
        <div class="timeline-row grid gap-4 sm:grid-cols-[5rem_1fr]">
          <div class="relative flex sm:justify-end">
            <span class="text-2xl font-semibold text-teal-500/90" style="font-family: var(--font-display)">{block.year}</span>
            {i < timeline.length - 1 && (
              <div class="absolute left-4 top-10 hidden h-full w-px bg-teal-800/40 sm:left-auto sm:right-0 sm:block" aria-hidden="true"></div>
            )}
          </div>
          <ul class="space-y-2 border-l border-teal-800/30 pb-10 pl-6 sm:border-l-0 sm:pl-0">
            {block.items.map((item) => (
              <li class="flex items-center gap-3 text-sm">
                <span class:list={[item.done ? "text-teal-500" : "text-slate-600"]}>
                  {item.done ? "✓" : "○"}
                </span>
                <span class:list={[item.done ? "text-slate-200" : "text-slate-500"]}>{item.label}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>
