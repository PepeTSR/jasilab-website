---
import { cvtPath } from "../../lib/site";
import MapNode from "./MapNode.astro";

const pillars = [
  { title: "PEOPLE", items: "Identity · Skills · Experience", href: cvtPath("concepts/trust-profile") },
  { title: "VEHICLES", items: "Plates · Verification · Reports", href: cvtPath("roadmap#phases") },
  { title: "TRUST", items: "Timeline · Standing · Passport", href: cvtPath("guides/building-a-trust-passport") },
  { title: "OPPORTUNITIES", items: "Employment · Insurance · Finance", href: cvtPath("guides/partner-integration") },
  { title: "ECOSYSTEM", items: "Public · Employers · Insurers · Fleets · Banks · SACCOs", href: "#ecosystem" },
];
---

<section class="map-section flagship" id="vision">
  <p class="map-kicker">4 · Long-term vision</p>
  <h2 class="map-heading">Trust infrastructure for everyday work</h2>
  <p class="map-lead">The transport pilot is the entry point. The destination is portable trust for service providers across Africa.</p>

  <div class="mt-10 overflow-hidden rounded-md border-2 border-primary/40 bg-canvas">
    <div class="border-b border-hairline px-6 py-8 text-center sm:px-10">
      <p class="text-3xl font-bold tracking-tight text-ink-strong sm:text-4xl">CVT</p>
      <p class="mt-1 text-sm text-primary">Connected Verification Terminal</p>
    </div>

    {pillars.map((p) => (
      <>
        <div class="mx-6 border-t border-dashed border-hairline sm:mx-10" aria-hidden="true"></div>
        <a href={p.href} class="block px-6 py-8 text-center transition hover:bg-canvas-soft sm:px-10">
          <p class="eyebrow-mono !text-[11px] !tracking-[0.25em]">{p.title}</p>
          <p class="mt-3 text-base text-body sm:text-lg">{p.items}</p>
        </a>
      </>
    ))}
  </div>
</section>
