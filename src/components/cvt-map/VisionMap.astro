---
import MapNode from "./MapNode.astro";

const pillars = [
  { title: "PEOPLE", items: "Identity · Skills · Experience", href: "/cvt/concepts/trust-profile" },
  { title: "VEHICLES", items: "Plates · Verification · Reports", href: "/cvt/docs/registry-categories" },
  { title: "TRUST", items: "Timeline · Standing · Passport", href: "/cvt/guides/building-a-trust-passport" },
  { title: "OPPORTUNITIES", items: "Employment · Insurance · Finance", href: "/cvt/guides/partner-integration" },
  { title: "ECOSYSTEM", items: "Public · Employers · Insurers · Fleets · Banks · SACCOs", href: "#ecosystem" },
];
---

<section class="map-section flagship" id="vision">
  <p class="map-kicker">4 · Long-term vision</p>
  <h2 class="map-heading">Mobility reputation infrastructure for Africa</h2>
  <p class="map-lead">From a WhatsApp plate lookup to a continent-scale trust and opportunity network.</p>

  <div class="flagship-diagram mt-10 overflow-hidden rounded-2xl border border-teal-800/40 bg-gradient-to-b from-slate-900 to-slate-950">
    <div class="border-b border-white/10 px-6 py-8 text-center sm:px-10">
      <p class="text-3xl font-bold tracking-tight text-white sm:text-4xl">CVT</p>
      <p class="mt-1 text-sm text-teal-400">Connected Verification Trust</p>
    </div>

    {pillars.map((p, i) => (
      <>
        <div class="flagship-divider mx-6 border-t border-dashed border-teal-800/50 sm:mx-10" aria-hidden="true"></div>
        <a href={p.href} class="flagship-block block px-6 py-8 text-center transition hover:bg-white/[0.03] sm:px-10">
          <p class="text-xs font-bold uppercase tracking-[0.25em] text-teal-500">{p.title}</p>
          <p class="mt-3 text-base text-slate-300 sm:text-lg">{p.items}</p>
        </a>
      </>
    ))}
  </div>
</section>
