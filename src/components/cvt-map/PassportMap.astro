---
import { cvtPath } from "../../lib/site";
import MapNode from "./MapNode.astro";
---

<section class="map-section" id="trust-passport">
  <p class="map-kicker">3 · Where the pilot leads</p>
  <h2 class="map-heading">The Trust Passport</h2>
  <p class="map-lead">Transport verification feeds a portable surface that works for any service provider — three pillars today, more signal layers as categories expand.</p>

  <div class="ecosystem-grid mt-10">
    <div class="flex justify-center">
      <MapNode label="Trust Passport" variant="hub" class="min-w-[11rem]" href={cvtPath("guides/building-a-trust-passport")} />
    </div>
    <div class="mx-auto mt-2 h-8 w-px bg-hairline" aria-hidden="true"></div>
    <div class="grid gap-4 sm:grid-cols-3">
      <MapNode label="Trust Profile" href={cvtPath("concepts/trust-profile")} />
      <MapNode label="Trust Timeline" href={cvtPath("concepts/trust-timeline")} />
      <MapNode label="Trust Level" href={cvtPath("concepts/trust-level")} />
    </div>
    <div class="mx-auto mt-2 h-8 w-full max-w-md text-hairline">
      <svg class="h-full w-full" viewBox="0 0 400 32" preserveAspectRatio="none" fill="none" aria-hidden="true">
        <path d="M67 0 V16 H200 M333 0 V16 H200 M200 16 V32" stroke="currentColor" stroke-width="1" />
      </svg>
    </div>
    <div class="flex justify-center">
      <MapNode label="Good Standing" variant="highlight" href={cvtPath("concepts/good-standing")} class="min-w-[10rem]" />
    </div>

    <p class="mt-8 text-center eyebrow-mono !text-[11px] !tracking-[0.2em] text-mute">Future additions</p>
    <div class="mx-auto mt-4 h-6 w-px bg-hairline" aria-hidden="true"></div>
    <div class="mt-4 grid gap-3 sm:grid-cols-3">
      <MapNode label="Skills & Qualifications" variant="future" />
      <MapNode label="Employment History" variant="future" />
      <MapNode label="Insurance History" variant="future" />
    </div>
  </div>
</section>
