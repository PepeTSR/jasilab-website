---
import { jasiLabNav } from "../lib/nav";
const current = Astro.url.pathname;
---

<header class="nav-bar sticky top-0 z-50">
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-6 px-4 py-3 sm:px-8">
    <a href="/" class="flex items-baseline gap-2">
      <span class="text-lg font-semibold tracking-tight text-ink-strong">JasiLab</span>
      <span class="hidden text-xs text-mute sm:inline">Research · Products</span>
    </a>
    <nav class="flex flex-wrap items-center gap-1">
      {jasiLabNav.map((item) => (
        <a
          href={item.href}
          class:list={[
            current === item.href || (item.href !== "/" && current.startsWith(item.href))
              ? "nav-link-active"
              : "nav-link",
          ]}
        >
          {item.label}
        </a>
      ))}
    </nav>
  </div>
</header>
