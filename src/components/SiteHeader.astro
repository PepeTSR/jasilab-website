---
import { jasiLabNav } from "../lib/nav";
const current = Astro.url.pathname;
---

<header class="border-b border-slate-200 bg-white/90 backdrop-blur">
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-6 px-4 py-4 sm:px-6">
    <a href="/" class="group flex items-baseline gap-2">
      <span class="font-display text-xl font-semibold tracking-tight text-slate-900">JasiLab</span>
      <span class="hidden text-xs text-slate-500 sm:inline">Research · Products</span>
    </a>
    <nav class="flex flex-wrap items-center gap-1 sm:gap-2">
      {jasiLabNav.map((item) => (
        <a
          href={item.href}
          class:list={[
            "rounded-md px-3 py-2 text-sm font-medium transition",
            current === item.href || current.startsWith(item.href + "/")
              ? "bg-slate-100 text-slate-900"
              : "text-slate-600 hover:bg-slate-50 hover:text-slate-900",
          ]}
        >
          {item.label}
        </a>
      ))}
    </nav>
  </div>
</header>

<style>
  .font-display { font-family: "Fraunces", Georgia, serif; }
</style>
