---
import type { RoadmapPhase } from "../../lib/cvt-roadmap";

interface Props {
  phase: RoadmapPhase;
}

const { phase } = Astro.props;

const statusLabel = {
  live: "Live today",
  building: "In progress",
  planned: "Planned",
};

const phaseClass = {
  live: "phase-live",
  building: "phase-building",
  planned: "phase-planned",
};

const statusClass = {
  live: "status-live",
  building: "status-building",
  planned: "status-planned",
};
---

<article class:list={[phaseClass[phase.status]]} id={`phase-${phase.number}`}>
  <div class="flex flex-wrap items-start justify-between gap-3">
    <div>
      <p class="eyebrow-mono !text-[11px] !tracking-[0.2em] text-mute">Phase {phase.number}</p>
      <h3 class="mt-1 text-xl font-semibold text-ink-strong sm:text-2xl">{phase.title}</h3>
      {phase.subtitle && <p class="mt-1 text-sm text-primary">{phase.subtitle}</p>}
    </div>
    <span class:list={["pill-tag border-current", statusClass[phase.status]]}>
      {statusLabel[phase.status]}
    </span>
  </div>

  <div class="mt-6 grid gap-6 lg:grid-cols-2">
    <div>
      <p class="eyebrow-mono !text-[11px] !tracking-[0.2em] text-mute">Goal</p>
      <p class="mt-2 text-ink">{phase.goal}</p>

      <p class="mt-6 eyebrow-mono !text-[11px] !tracking-[0.2em] text-mute">Why it matters</p>
      <p class="map-quote mt-2 !text-base !not-italic">{phase.impact}</p>
    </div>

    <div>
      <p class="eyebrow-mono !text-[11px] !tracking-[0.2em] text-mute">Capabilities</p>
      <ul class="mt-3 space-y-2">
        {phase.features.map((f) => (
          <li class="flex items-start gap-2 text-sm">
            <span class:list={[
              "mt-0.5 shrink-0",
              f.done ? "text-primary" : phase.status === "planned" ? "text-mute" : "text-amber-400",
            ]}>
              {f.done ? "✓" : phase.status === "planned" ? "○" : "◐"}
            </span>
            {f.href ? (
              <a href={f.href} class="text-body hover:text-primary-soft hover:underline">{f.label}</a>
            ) : (
              <span class="text-mute">{f.label}</span>
            )}
          </li>
        ))}
      </ul>
      {phase.number === 4 && (
        <p class="mt-4 text-xs text-mute">
          Partners: Insurers · Employers · Fleet operators · Banks · SACCOs
        </p>
      )}
    </div>
  </div>
</article>
