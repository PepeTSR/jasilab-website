---
import MapNode from "../cvt-map/MapNode.astro";
---

<section class="map-section" id="project-map">
  <p class="map-kicker">Project map</p>
  <h2 class="map-heading">From pilot to platform</h2>
  <p class="map-lead">How today's transport verification grows into economic opportunity — one layer at a time.</p>

  <div class="ecosystem-grid mx-auto mt-10 max-w-md">
    <p class="text-center eyebrow-mono !text-[11px] !tracking-[0.2em]">Trust infrastructure</p>

    <div class="mt-6 flex flex-col items-center gap-0">
      <MapNode label="Citizens" variant="default" class="w-full max-w-[12rem]" />
      <div class="h-5 w-px bg-hairline" aria-hidden="true"></div>
      <span class="text-primary/50" aria-hidden="true">↑</span>
      <div class="h-3 w-px bg-hairline" aria-hidden="true"></div>
      <MapNode label="WhatsApp Lookup" href="/cvt/map#user-layer" variant="highlight" class="w-full max-w-[14rem]" />
      <div class="h-5 w-px bg-hairline" aria-hidden="true"></div>
      <MapNode label="Vehicle Registry" class="w-full max-w-[14rem]" />
      <div class="h-5 w-px bg-hairline" aria-hidden="true"></div>
      <MapNode label="Incident Moderation" href="/cvt/guides/moderation-framework" class="w-full max-w-[14rem]" />
      <div class="h-5 w-px bg-hairline" aria-hidden="true"></div>
      <MapNode label="Trust Profile" sub="Level + Timeline" href="/cvt/map#trust-passport" variant="hub" class="w-full max-w-[16rem]" />

      <div class="my-4 h-8 w-full max-w-xs text-hairline">
        <svg viewBox="0 0 200 32" class="h-full w-full" fill="none" aria-hidden="true">
          <path d="M100 0 V8 M33 8 H167 M33 8 V16 M100 8 V32 M167 8 V16" stroke="currentColor" stroke-width="1" />
        </svg>
      </div>

      <div class="grid w-full grid-cols-3 gap-2">
        <MapNode label="Insurance" href="/cvt/guides/insurance" class="!px-2 !py-2 text-xs" />
        <MapNode label="Employers" href="/cvt/guides/employment" class="!px-2 !py-2 text-xs" />
        <MapNode label="Banks" href="/cvt/guides/consent-framework" class="!px-2 !py-2 text-xs" />
      </div>

      <div class="mt-4 h-5 w-px bg-hairline" aria-hidden="true"></div>
      <MapNode label="Economic Opportunity" variant="highlight" class="w-full max-w-[16rem]" />
    </div>
  </div>
</section>
