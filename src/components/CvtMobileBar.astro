---
import { cvtAppUrl, getCvtPrimaryCta } from "../lib/nav";
import { isSuperhumanTheme } from "../lib/cvt-theme";

const primaryCta = getCvtPrimaryCta(Astro.url.pathname);
---

<div class="fixed inset-x-0 bottom-0 z-40 border-t border-hairline bg-canvas/95 p-3 backdrop-blur-sm sm:hidden">
  <div class="mx-auto flex max-w-lg gap-2">
    <a href={primaryCta.href} target="_blank" rel="noopener" class="btn-primary flex-1 !py-2.5 !text-sm">
      {primaryCta.label}
    </a>
    {!isSuperhumanTheme && (
      <a href={cvtAppUrl} target="_blank" rel="noopener" class="btn-outline flex-1 !py-2.5 !text-sm">
        Registry ↗
      </a>
    )}
  </div>
</div>
