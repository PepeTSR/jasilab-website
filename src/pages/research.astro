---
import JasiLabLayout from "../layouts/JasiLabLayout.astro";
---

<JasiLabLayout title="Research — JasiLab">
  <section class="section-band max-w-3xl">
    <h1 class="display-lg">Research</h1>
    <p class="lead mt-4">Themes we explore across JasiLab products and writing.</p>
    <ul class="mt-8 space-y-4">
      <li class="card-feature"><strong class="text-ink-strong">Trust as infrastructure</strong> — portable standing built from verified facts, not rumours.</li>
      <li class="card-feature"><strong class="text-ink-strong">Informal economies</strong> — systems designed for Uganda and Africa, not imported credit models.</li>
      <li class="card-feature"><strong class="text-ink-strong">Insurance before credit</strong> — insurer signals before CRB integration.</li>
      <li class="card-feature"><strong class="text-ink-strong">Rehabilitation</strong> — complaints should not permanently destroy reputations.</li>
    </ul>
  </section>
</JasiLabLayout>
