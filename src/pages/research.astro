---
import JasiLabLayout from "../layouts/JasiLabLayout.astro";
---

<JasiLabLayout title="Research — JasiLab">
  <div class="mx-auto max-w-3xl px-4 py-16 sm:px-6">
    <h1 class="font-display text-4xl font-semibold text-slate-900">Research</h1>
    <p class="mt-6 text-lg text-slate-600">Themes we explore across JasiLab products and writing.</p>
    <ul class="mt-8 space-y-4 text-slate-700">
      <li class="rounded-xl border border-slate-200 p-5"><strong class="text-slate-900">Trust as infrastructure</strong> — portable standing built from verified facts, not rumours.</li>
      <li class="rounded-xl border border-slate-200 p-5"><strong class="text-slate-900">Informal economies</strong> — systems designed for Uganda and Africa, not imported credit models.</li>
      <li class="rounded-xl border border-slate-200 p-5"><strong class="text-slate-900">Insurance before credit</strong> — insurer signals before CRB integration.</li>
      <li class="rounded-xl border border-slate-200 p-5"><strong class="text-slate-900">Rehabilitation</strong> — complaints should not permanently destroy reputations.</li>
    </ul>
  </div>
</JasiLabLayout>

<style>.font-display { font-family: "Fraunces", Georgia, serif; }</style>
