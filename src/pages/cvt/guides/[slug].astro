---
import { getCollection, render } from "astro:content";
import CvtLayout from "../../../layouts/CvtLayout.astro";

export async function getStaticPaths() {
  const guides = await getCollection("cvtGuides");
  return guides.map((guide) => ({ params: { slug: guide.id }, props: { guide } }));
}

const { guide } = Astro.props;
const { Content } = await render(guide);
const allGuides = (await getCollection("cvtGuides")).sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
---

<CvtLayout title={`${guide.data.title} — CVT Guides`} description={guide.data.description}>
  <div class="mx-auto flex max-w-6xl flex-col gap-10 px-4 py-12 lg:flex-row lg:px-6">
    <aside class="lg:w-56 lg:shrink-0">
      <p class="text-xs font-medium uppercase tracking-widest text-slate-500">Guides</p>
      <nav class="mt-4 space-y-1">
        {allGuides.map((g) => (
          <a
            href={`/cvt/guides/${g.id}`}
            class:list={[
              "block rounded-md px-3 py-2 text-sm",
              g.id === guide.id ? "bg-teal-900/40 text-teal-200" : "text-slate-400 hover:bg-white/5 hover:text-white",
            ]}
          >
            {g.data.title}
          </a>
        ))}
      </nav>
    </aside>
    <article class="min-w-0 flex-1 rounded-2xl border border-white/10 bg-white p-8 text-slate-800 shadow-xl sm:p-10">
      <header class="mb-8 border-b border-slate-200 pb-6">
        <a href="/cvt/guides" class="text-sm text-teal-700 hover:underline">← All guides</a>
        {guide.data.description && <p class="mt-3 text-slate-600">{guide.data.description}</p>}
      </header>
      <div class="doc-content">
        <Content />
      </div>
    </article>
  </div>
</CvtLayout>
