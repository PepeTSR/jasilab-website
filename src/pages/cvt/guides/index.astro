---
import { getCollection } from "astro:content";
import CvtLayout from "../../../layouts/CvtLayout.astro";

const guides = (await getCollection("cvtGuides")).sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
---

<CvtLayout title="Guides — CVT" description="How-to documents for integrators, insurers, employers, and CVT operators.">
  <section class="section-band max-w-3xl">
    <h1 class="display-lg">Guides</h1>
    <p class="mt-4 text-body">Policy and integration overviews for operators and partners. Detailed specifications are available under partner agreement.</p>
    <ul class="mt-10 divide-y divide-hairline rounded-md border border-hairline">
      {guides.map((guide) => (
        <li>
          <a href={`/cvt/guides/${guide.id}`} class="block px-5 py-4 transition hover:bg-canvas-soft">
            <p class="font-semibold text-ink-strong">{guide.data.title}</p>
            {guide.data.description && <p class="mt-1 text-sm text-mute">{guide.data.description}</p>}
          </a>
        </li>
      ))}
    </ul>
  </section>
</CvtLayout>
