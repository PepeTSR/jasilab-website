---
import { getCollection } from "astro:content";
import CvtLayout from "../../../layouts/CvtLayout.astro";

const guides = (await getCollection("cvtGuides")).sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
---

<CvtLayout title="Guides — CVT" description="How-to documents for integrators, insurers, employers, and CVT operators.">
  <div class="mx-auto max-w-3xl px-4 py-16 sm:px-6">
    <h1 class="font-display text-4xl font-semibold text-white">Guides</h1>
    <p class="mt-4 text-slate-400">How-to documents for integrators and operators. Full specifications live in <a href="/cvt/docs" class="text-teal-400 hover:underline">Documents</a>.</p>
    <ul class="mt-10 divide-y divide-white/10 rounded-xl border border-white/10">
      {guides.map((guide) => (
        <li>
          <a href={`/cvt/guides/${guide.id}`} class="block px-5 py-4 transition hover:bg-white/5">
            <p class="font-medium text-white">{guide.data.title}</p>
            {guide.data.description && <p class="mt-1 text-sm text-slate-500">{guide.data.description}</p>}
          </a>
        </li>
      ))}
    </ul>
  </div>
</CvtLayout>

<style>.font-display { font-family: "Fraunces", Georgia, serif; }</style>
