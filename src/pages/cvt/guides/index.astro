---
import { cvtPath } from "../../../lib/site";
import { getPublicGuides } from "../../../lib/cvt-guides";
import CvtLayout from "../../../layouts/CvtLayout.astro";

const guides = await getPublicGuides();
---

<CvtLayout title="Guides — CVT" description="Policy and integration overviews for CVT operators and partners.">
  <section class="section-band max-w-3xl">
    <h1 class="display-lg">Guides</h1>
    <p class="mt-4 text-body">
      Public policy overviews for operators and partners. Technical API documentation is available under partner agreement — see{" "}
      <a href={cvtPath("partners")}>Partners</a>.
    </p>
    <ul class="mt-10 divide-y divide-hairline rounded-md border border-hairline">
      {guides.map((guide) => (
        <li>
          <a href={cvtPath(`guides/${guide.id}`)} class="block px-5 py-4 transition hover:bg-canvas-soft">
            <p class="font-semibold text-ink-strong">{guide.data.title}</p>
            {guide.data.description && <p class="mt-1 text-sm text-mute">{guide.data.description}</p>}
          </a>
        </li>
      ))}
    </ul>
  </section>
</CvtLayout>
