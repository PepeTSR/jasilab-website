---
import CvtLayout from "../../layouts/CvtLayout.astro";
import WhatsAppMagic from "../../components/cvt-home/WhatsAppMagic.astro";
import DocsFooter from "../../components/cvt-home/DocsFooter.astro";
import { cvtWhatsAppUrl, cvtLiveFeatures } from "../../lib/nav";

const howItWorks = [
  { title: "Verify", body: "Field teams and approved staff register drivers and vehicles, verify documents, and maintain an auditable registry." },
  { title: "Lookup", body: "Anyone can use WhatsApp to check the verification status of a number plate. Unknown vehicles can be captured and added to the network over time." },
  { title: "Build Trust", body: "Trust grows through verified history, training, insurance, and positive conduct. Complaints only affect trust after moderation and review." },
  { title: "Share With Consent", body: "Drivers can share their Trust Profile with employers, fleets, or insurers for employment, onboarding, or underwriting purposes." },
  { title: "Reward Good Behaviour", body: "CVT focuses on long-term reputation and rehabilitation rather than punishment. Trust is based on verified facts and evolves over time." },
];

const trustEarned = ["Verification", "Time", "Training", "Insurance", "Good conduct"];
---

<CvtLayout
  title="CVT — Building trust for transport"
  description="CVT is a transport trust network. Verify drivers and vehicles through WhatsApp and build reputation over time."
>
  <section class="section-band border-b border-hairline">
    <div class="grid gap-12 lg:grid-cols-[1fr_minmax(280px,360px)] lg:items-start">
      <div>
        <p class="eyebrow-mono">Connected Verification Trust</p>
        <h1 class="display-xl mt-4 max-w-2xl">Building trust for transport.</h1>
        <p class="mt-5 text-xl text-ink">Verify drivers. Check number plates. Build reputation over time.</p>
        <p class="mt-4 max-w-xl text-body">
          A transport trust network — verify through WhatsApp, grow a shared registry, and earn standing that travels with you.
        </p>

        <div class="mt-8">
          <p class="eyebrow-mono !text-[11px] !tracking-[0.2em] text-primary">Already live</p>
          <ul class="mt-3 flex flex-wrap gap-2">
            {cvtLiveFeatures.map((f) => (
              <li class="pill-tag-live"><span class="text-primary">✓</span> {f}</li>
            ))}
          </ul>
        </div>

        <div class="mt-10 flex flex-wrap gap-3">
          <a href={cvtWhatsAppUrl} target="_blank" rel="noopener" class="btn-primary">Try WhatsApp Lookup</a>
          <a href="#what-is-cvt" class="btn-outline">Learn more</a>
        </div>
      </div>

      <div class="code-mockup">
        <p class="text-mute mb-3 text-xs uppercase tracking-widest">WhatsApp lookup</p>
        <p><span class="text-primary">→</span> Send plate photo</p>
        <p><span class="text-primary">→</span> <span class="text-body">+256 792 497830</span></p>
        <p class="mt-4 text-mute">// response</p>
        <p class="text-primary-soft">status: verified</p>
        <p>vehicle: <span class="text-ink">Boda · CVT-RDR-2026-000042</span></p>
        <p>standing: <span class="text-primary">Good Standing</span></p>
      </div>
    </div>
  </section>

  <WhatsAppMagic />

  <section id="what-is-cvt" class="section-band section-divider scroll-mt-20">
    <h2 class="display-md">What is CVT?</h2>
    <div class="mt-6 max-w-3xl space-y-4 text-lg leading-relaxed text-body">
      <p><strong class="text-ink-strong">CVT (Connected Verification Trust)</strong> is a trust platform for transport.</p>
      <p>It helps people verify drivers and vehicles, check registration status through WhatsApp, and build reputation over time.</p>
      <p>Drivers earn trust through verification, training, insurance, and good conduct. Employers, fleets, and insurers can access trusted information with consent, while individuals remain in control of their records.</p>
      <p class="text-mute">CVT supports accountability and transparency without turning trust into a hidden score or permanent blacklist.</p>
    </div>
  </section>

  <section class="section-band section-divider border-t border-hairline bg-canvas-soft/30">
    <h2 class="display-md">How CVT works</h2>
    <ol class="mt-10 max-w-3xl space-y-8">
      {howItWorks.map((step, i) => (
        <li class="flex gap-5">
          <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-sm border border-primary/40 bg-canvas text-sm font-semibold text-primary">
            {i + 1}
          </span>
          <div>
            <h3 class="text-lg font-semibold text-ink-strong">{step.title}</h3>
            <p class="mt-2 leading-relaxed text-body">{step.body}</p>
          </div>
        </li>
      ))}
    </ol>
  </section>

  <section class="section-band green-divider-band">
    <h2 class="display-md">Trust grows over time</h2>
    <p class="map-lead">Not a hidden score — a passport built from verified facts.</p>

    <div class="mt-10 flex flex-wrap items-center justify-center gap-3 sm:gap-4">
      <a href="/cvt/concepts/trust-profile" class="card-feature !py-4 text-sm font-semibold">Trust Profile</a>
      <span class="text-xl text-primary/50">+</span>
      <a href="/cvt/concepts/trust-timeline" class="card-feature !py-4 text-sm font-semibold">Trust Timeline</a>
      <span class="text-xl text-primary/50">+</span>
      <a href="/cvt/concepts/trust-level" class="card-feature !py-4 text-sm font-semibold">Trust Level</a>
      <span class="text-xl text-primary/50">=</span>
      <a href="/cvt/concepts/trust-passport" class="card-feature-emphasis !py-4 text-sm font-semibold text-primary-soft">Trust Passport</a>
    </div>

    <p class="mt-8 text-center text-sm text-mute">Trust is earned through</p>
    <div class="mt-4 flex flex-wrap justify-center gap-2">
      {trustEarned.map((t) => <span class="pill-tag">{t}</span>)}
    </div>
    <p class="mt-8 text-center">
      <a href="/cvt/guides/building-a-trust-passport" class="btn-ghost !text-sm">How to build a Trust Passport →</a>
    </p>
  </section>

  <DocsFooter />
</CvtLayout>
