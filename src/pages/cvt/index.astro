---
import CvtLayout from "../../layouts/CvtLayout.astro";
import WhatsAppMagic from "../../components/cvt-home/WhatsAppMagic.astro";
import DocsFooter from "../../components/cvt-home/DocsFooter.astro";
import { cvtAppUrl, cvtWhatsAppUrl, cvtLiveFeatures } from "../../lib/nav";

const howItWorks = [
  {
    title: "Verify",
    body: "Field teams and approved staff register drivers and vehicles, verify documents, and maintain an auditable registry.",
  },
  {
    title: "Lookup",
    body: "Anyone can use WhatsApp to check the verification status of a number plate. Unknown vehicles can be captured and added to the network over time.",
  },
  {
    title: "Build Trust",
    body: "Trust grows through verified history, training, insurance, and positive conduct. Complaints only affect trust after moderation and review.",
  },
  {
    title: "Share With Consent",
    body: "Drivers can share their Trust Profile with employers, fleets, or insurers for employment, onboarding, or underwriting purposes.",
  },
  {
    title: "Reward Good Behaviour",
    body: "CVT focuses on long-term reputation and rehabilitation rather than punishment. Trust is based on verified facts and evolves over time.",
  },
];

const trustEarned = ["Verification", "Time", "Training", "Insurance", "Good conduct"];
---

<CvtLayout
  title="CVT — Building trust for transport"
  description="CVT is a transport trust network. Verify drivers and vehicles through WhatsApp and build reputation over time."
>
  <!-- Hero -->
  <section class="relative overflow-hidden border-b border-white/10">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-teal-900/30 via-slate-950 to-slate-950" />
    <div class="relative mx-auto max-w-6xl px-4 py-16 sm:px-6 sm:py-24">
      <p class="text-sm font-medium uppercase tracking-widest text-teal-400">Connected Verification Trust</p>
      <h1 class="mt-3 max-w-3xl font-display text-4xl font-semibold leading-tight text-white sm:text-5xl">
        Building trust for transport.
      </h1>
      <p class="mt-5 max-w-2xl text-xl text-slate-300">
        Verify drivers. Check number plates. Build reputation over time.
      </p>
      <p class="mt-4 max-w-2xl text-base text-slate-500">
        CVT is a transport trust network — verify through WhatsApp, grow a shared registry, and earn standing that travels with you.
      </p>

      <div class="mt-8">
        <p class="text-xs font-bold uppercase tracking-widest text-teal-500">Already live</p>
        <ul class="mt-3 flex flex-wrap gap-x-6 gap-y-2">
          {cvtLiveFeatures.map((f) => (
            <li class="flex items-center gap-2 text-sm text-slate-300">
              <span class="text-teal-500">✓</span> {f}
            </li>
          ))}
        </ul>
      </div>

      <div class="mt-10 flex flex-wrap gap-4">
        <a href={cvtWhatsAppUrl} class="rounded-full bg-teal-600 px-6 py-3 text-sm font-medium text-white hover:bg-teal-500">
          Try WhatsApp Lookup
        </a>
        <a href="#what-is-cvt" class="rounded-full border border-white/20 px-6 py-3 text-sm font-medium text-slate-200 hover:bg-white/5">
          Learn more
        </a>
      </div>
    </div>
  </section>

  <!-- WhatsApp magic + ecosystem -->
  <WhatsAppMagic />

  <!-- What is CVT -->
  <section id="what-is-cvt" class="mx-auto max-w-3xl px-4 py-16 sm:px-6 scroll-mt-20">
    <h2 class="font-display text-3xl font-semibold text-white">What is CVT?</h2>
    <div class="mt-6 space-y-4 text-lg leading-relaxed text-slate-300">
      <p>
        <strong class="text-white">CVT (Connected Verification Trust)</strong> is a trust platform for transport.
      </p>
      <p>
        It helps people verify drivers and vehicles, check registration status through WhatsApp, and build reputation over time.
      </p>
      <p>
        Drivers earn trust through verification, training, insurance, and good conduct. Employers, fleets, and insurers can access trusted information with consent, while individuals remain in control of their records.
      </p>
      <p class="text-slate-400">
        CVT is designed to support accountability and transparency without turning trust into a hidden score or permanent blacklist.
      </p>
    </div>
  </section>

  <!-- How it works -->
  <section class="border-y border-white/10 bg-slate-900/30">
    <div class="mx-auto max-w-3xl px-4 py-16 sm:px-6">
      <h2 class="font-display text-3xl font-semibold text-white">How CVT works</h2>
      <ol class="mt-10 space-y-8">
        {howItWorks.map((step, i) => (
          <li class="flex gap-5">
            <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-teal-900/50 text-sm font-semibold text-teal-300">
              {i + 1}
            </span>
            <div>
              <h3 class="text-lg font-semibold text-white">{step.title}</h3>
              <p class="mt-2 text-slate-400 leading-relaxed">{step.body}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- Trust Profiles (simple) -->
  <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6">
    <h2 class="font-display text-2xl font-semibold text-white sm:text-3xl">Trust grows over time</h2>
    <p class="mt-3 max-w-2xl text-slate-400">Not a hidden score — a passport built from verified facts.</p>

    <div class="mt-10 flex flex-wrap items-center justify-center gap-3 text-center sm:gap-4">
      <a href="/cvt/concepts/trust-profile" class="rounded-xl border border-white/15 bg-white/5 px-5 py-4 text-sm font-semibold text-white hover:border-teal-600/40">Trust Profile</a>
      <span class="text-2xl text-teal-600/60">+</span>
      <a href="/cvt/concepts/trust-timeline" class="rounded-xl border border-white/15 bg-white/5 px-5 py-4 text-sm font-semibold text-white hover:border-teal-600/40">Trust Timeline</a>
      <span class="text-2xl text-teal-600/60">+</span>
      <a href="/cvt/concepts/trust-level" class="rounded-xl border border-white/15 bg-white/5 px-5 py-4 text-sm font-semibold text-white hover:border-teal-600/40">Trust Level</a>
      <span class="text-2xl text-teal-600/60">=</span>
      <a href="/cvt/concepts/trust-passport" class="rounded-xl border border-teal-600/40 bg-teal-950/40 px-5 py-4 text-sm font-semibold text-teal-200 hover:bg-teal-900/40">Trust Passport</a>
    </div>

    <p class="mt-8 text-center text-sm text-slate-500">Trust is earned through</p>
    <div class="mt-4 flex flex-wrap justify-center gap-2">
      {trustEarned.map((t) => (
        <span class="rounded-full border border-white/10 px-4 py-1.5 text-sm text-slate-300">{t}</span>
      ))}
    </div>
    <p class="mt-8 text-center">
      <a href="/cvt/guides/building-a-trust-passport" class="text-sm text-teal-400 hover:underline">How to build a Trust Passport →</a>
    </p>
  </section>

  <!-- Docs footer -->
  <DocsFooter />
</CvtLayout>

<style>.font-display { font-family: "Fraunces", Georgia, serif; }</style>
