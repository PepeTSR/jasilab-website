---
import { cvtPath } from "../../lib/site";
import CvtLayout from "../../layouts/CvtLayout.astro";
import WhatsAppMagic from "../../components/cvt-home/WhatsAppMagic.astro";
import JourneyPath from "../../components/cvt-home/JourneyPath.astro";
import DocsFooter from "../../components/cvt-home/DocsFooter.astro";
import { cvtWhatsAppUrl } from "../../lib/nav";
import { cvtPlatformTagline, cvtPilotLabel, cvtPilotCapabilities } from "../../lib/cvt-narrative";

const howItWorks = [
  {
    title: "Verify",
    body: "Approved staff register people and assets, verify documents, and maintain an auditable registry. Today this covers boda riders, taxis and special hire in Kampala; the same process extends to other service categories.",
  },
  {
    title: "Lookup",
    body: "Anyone can check verification status through channels people already use. The pilot runs on WhatsApp plate lookup — unknown vehicles are captured and added to the network over time.",
  },
  {
    title: "Build trust",
    body: "Trust grows through verified history, training, insurance, and positive conduct. Complaints only affect standing after moderation and review — not from raw accusations.",
  },
  {
    title: "Share with consent",
    body: "Workers can share their Trust Profile with employers, fleets, insurers or partners. Individuals remain in control of what is disclosed and to whom.",
  },
  {
    title: "Reward good behaviour",
    body: "CVT focuses on long-term reputation and rehabilitation rather than punishment. Trust is based on verified facts and evolves over time.",
  },
];

const trustEarned = ["Verification", "Time", "Training", "Insurance", "Good conduct"];
---

<CvtLayout
  title="CVT — Trust. Visibility. Accountability."
  description="CVT is a public trust platform for mobile identities. Commercial transport in Uganda is the first pilot — verify through WhatsApp and build reputation that travels with you."
>
  <!-- Hero: platform first -->
  <section class="section-band border-b border-hairline">
    <div class="grid gap-12 lg:grid-cols-[1fr_minmax(280px,360px)] lg:items-start">
      <div>
        <p class="eyebrow-mono">Connected Verification Terminal</p>
        <h1 class="display-xl mt-4 max-w-2xl">{cvtPlatformTagline}</h1>
        <p class="mt-5 text-xl text-ink">A public trust platform for people who provide services.</p>
        <p class="mt-4 max-w-xl text-body">
          Portable identities built from verification, qualifications, experience and accountable records — starting with commercial transport in Uganda.
        </p>

        <div class="mt-10 flex flex-wrap gap-3">
          <a href={cvtPath("vision")} class="btn-outline">Read the vision</a>
          <a href="#first-pilot" class="btn-primary">See the transport pilot</a>
        </div>
      </div>

      <div class="code-mockup">
        <p class="text-mute mb-3 text-xs uppercase tracking-widest">First pilot · WhatsApp lookup</p>
        <p><span class="text-primary">→</span> Send plate photo</p>
        <p><span class="text-primary">→</span> <span class="text-body">+256 792 497830</span></p>
        <p class="mt-4 text-mute">// response</p>
        <p class="text-primary-soft">status: verified</p>
        <p>vehicle: <span class="text-ink">Boda · CVT-RDR-2026-000042</span></p>
        <p>standing: <span class="text-primary">Good Standing</span></p>
      </div>
    </div>
  </section>

  <!-- What is CVT: vision-aligned story -->
  <section id="what-is-cvt" class="section-band section-divider scroll-mt-20">
    <p class="eyebrow-mono">What is CVT</p>
    <h2 class="display-xl mt-4">CVT</h2>
    <p class="mt-3 text-xl text-primary-soft">{cvtPlatformTagline}</p>

    <div class="mt-8 max-w-3xl space-y-5 text-lg leading-relaxed text-body">
      <p>
        <strong class="text-ink-strong">CVT (Connected Verification Terminal)</strong> is a public trust platform that helps people create trusted, mobile identities for the services they provide.
      </p>
      <p>
        Through verification, qualifications, experience and accountable service records, CVT enables workers and businesses to build reputations that travel with them.
      </p>
      <p>
        Starting with commercial transport in Uganda, CVT is building the infrastructure for trusted service delivery across the informal and formal economy.
      </p>
      <p>
        Whether you are a boda rider, taxi driver, plumber, electrician, nurse, nanny or small business owner, CVT helps people prove who they are, showcase their skills and create opportunities through trust.
      </p>
    </div>

    <p class="mt-10 max-w-3xl text-lg text-body">
      Transport is not our business.<br />
      <strong class="text-2xl font-semibold text-ink-strong">Trust is.</strong>
    </p>

    <p class="mt-6">
      <a href={cvtPath("vision")} class="btn-ghost !px-0 !text-sm">Why trust infrastructure matters →</a>
    </p>
  </section>

  <!-- First pilot: transport (what's live) -->
  <section id="first-pilot" class="section-band section-divider border-t border-hairline bg-canvas-soft/30 scroll-mt-20">
    <p class="eyebrow-mono">{cvtPilotLabel}</p>
    <h2 class="display-md mt-4">Where CVT starts — and what's live today</h2>
    <p class="map-lead mt-4 max-w-3xl">
      Commercial mobility is the first implementation: boda bodas, taxis and special hire in Kampala. Clear trust challenges, channels people already use, and a path from plate lookup to portable standing.
    </p>

    <ul class="mt-8 flex flex-wrap gap-2">
      {cvtPilotCapabilities.map((f) => (
        <li class="pill-tag-live"><span class="text-primary">✓</span> {f}</li>
      ))}
    </ul>

    <div class="mt-10 flex flex-wrap gap-3">
      <a href={cvtWhatsAppUrl} target="_blank" rel="noopener" class="btn-primary">Try WhatsApp Lookup</a>
      <a href={cvtPath("roadmap#live-today")} class="btn-outline">What else is operational</a>
    </div>
  </section>

  <WhatsAppMagic />

  <!-- How it works: general model, pilot today -->
  <section class="section-band section-divider border-t border-hairline">
    <p class="map-kicker">How it works</p>
    <h2 class="display-md">The trust model</h2>
    <p class="map-lead max-w-3xl">
      These steps apply to any service provider on CVT. The transport pilot in Kampala is the first place they run end-to-end — from registry to Trust Profile.
    </p>
    <ol class="mt-10 max-w-3xl space-y-8">
      {howItWorks.map((step, i) => (
        <li class="flex gap-5">
          <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-sm border border-primary/40 bg-canvas text-sm font-semibold text-primary">
            {i + 1}
          </span>
          <div>
            <h3 class="text-lg font-semibold text-ink-strong">{step.title}</h3>
            <p class="mt-2 leading-relaxed text-body">{step.body}</p>
          </div>
        </li>
      ))}
    </ol>
  </section>

  <!-- Trust infrastructure destination -->
  <section id="trust-infrastructure" class="section-band green-divider-band scroll-mt-20">
    <p class="map-kicker">Where it leads</p>
    <h2 class="display-md">Trust grows over time</h2>
    <p class="map-lead">Not a hidden score — a passport built from verified facts. The transport pilot feeds the same trust layer that will serve plumbers, caregivers and small businesses.</p>

    <div class="mt-10 flex flex-wrap items-center justify-center gap-3 sm:gap-4">
      <a href={cvtPath("concepts/trust-profile")} class="card-feature !py-4 text-sm font-semibold">Trust Profile</a>
      <span class="text-xl text-primary/50">+</span>
      <a href={cvtPath("concepts/trust-timeline")} class="card-feature !py-4 text-sm font-semibold">Trust Timeline</a>
      <span class="text-xl text-primary/50">+</span>
      <a href={cvtPath("concepts/trust-level")} class="card-feature !py-4 text-sm font-semibold">Trust Level</a>
      <span class="text-xl text-primary/50">=</span>
      <a href={cvtPath("concepts/trust-passport")} class="card-feature-emphasis !py-4 text-sm font-semibold text-primary-soft">Trust Passport</a>
    </div>

    <p class="mt-8 text-center text-sm text-mute">Trust is earned through</p>
    <div class="mt-4 flex flex-wrap justify-center gap-2">
      {trustEarned.map((t) => <span class="pill-tag">{t}</span>)}
    </div>
    <p class="mt-8 text-center">
      <a href={cvtPath("guides/building-a-trust-passport")} class="btn-ghost !text-sm">How to build a Trust Passport →</a>
    </p>
  </section>

  <JourneyPath />
  <DocsFooter />
</CvtLayout>
