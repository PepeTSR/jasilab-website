---
import CvtLayout from "../../../layouts/CvtLayout.astro";
import UserLayer from "../../../components/cvt-map/UserLayer.astro";
import EcosystemMap from "../../../components/cvt-map/EcosystemMap.astro";
import PassportMap from "../../../components/cvt-map/PassportMap.astro";
import VisionMap from "../../../components/cvt-map/VisionMap.astro";
import { cvtAppUrl } from "../../../lib/nav";

const sections = [
  { id: "user-layer", label: "User layer" },
  { id: "ecosystem", label: "Ecosystem" },
  { id: "trust-passport", label: "Trust Passport" },
  { id: "vision", label: "Vision" },
];
---

<CvtLayout title="The CVT Map — Connected Verification Trust" description="Visual map of CVT — from WhatsApp lookup to mobility reputation infrastructure for Africa.">
  <section class="relative overflow-hidden border-b border-white/10">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-teal-900/25 via-slate-950 to-slate-950" />
    <div class="relative mx-auto max-w-6xl px-4 py-16 sm:px-6 sm:py-20">
      <p class="text-sm font-medium uppercase tracking-widest text-teal-400">The CVT Map</p>
      <h1 class="mt-3 max-w-3xl font-display text-4xl font-semibold leading-tight text-white sm:text-5xl">
        How a plate lookup becomes trust infrastructure
      </h1>
      <p class="mt-5 max-w-2xl text-lg text-slate-400">
        One page to see the user experience, the ecosystem, the Trust Passport, and the long-term vision — from WhatsApp to opportunities across Africa.
      </p>
      <nav class="mt-8 flex flex-wrap gap-2">
        {sections.map((s) => (
          <a href={`#${s.id}`} class="rounded-full border border-white/15 px-3 py-1.5 text-xs font-medium text-slate-300 hover:border-teal-600/50 hover:text-teal-200">
            {s.label}
          </a>
        ))}
      </nav>
    </div>
  </section>

  <div class="mx-auto max-w-6xl space-y-24 px-4 py-16 sm:px-6 sm:py-20">
    <UserLayer />
    <EcosystemMap />
    <PassportMap />
    <VisionMap />

    <section class="rounded-2xl border border-white/10 bg-slate-900/40 px-6 py-10 text-center sm:px-10">
      <h2 class="map-heading text-xl">Implementation roadmap</h2>
      <p class="map-lead mx-auto mt-3">Eight phases — from vehicle verification to financial inclusion. What exists today, what comes next, and why it matters.</p>
      <a href="/cvt/roadmap" class="mt-6 inline-block rounded-full bg-teal-600 px-6 py-3 text-sm font-medium text-white hover:bg-teal-500">
        View the full roadmap →
      </a>
    </section>
  </div>

  <section class="border-t border-white/10 bg-slate-900/50">
    <div class="mx-auto flex max-w-6xl flex-col items-start justify-between gap-6 px-4 py-12 sm:flex-row sm:items-center sm:px-6">
      <div>
        <p class="font-display text-lg font-semibold text-white">Explore further</p>
        <p class="mt-1 text-sm text-slate-400">Docs, guides, and the live registry.</p>
      </div>
      <div class="flex flex-wrap gap-3">
        <a href="/cvt/vision" class="rounded-full border border-white/20 px-5 py-2.5 text-sm text-slate-200 hover:bg-white/5">Vision essay</a>
        <a href="/cvt/guides" class="rounded-full border border-white/20 px-5 py-2.5 text-sm text-slate-200 hover:bg-white/5">Guides</a>
        <a href={cvtAppUrl} target="_blank" rel="noopener" class="rounded-full bg-teal-600 px-5 py-2.5 text-sm font-medium text-white hover:bg-teal-500">Live app ↗</a>
      </div>
    </div>
  </section>
</CvtLayout>
