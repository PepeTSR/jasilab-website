---
import CvtLayout from "../../../layouts/CvtLayout.astro";
import UserLayer from "../../../components/cvt-map/UserLayer.astro";
import EcosystemMap from "../../../components/cvt-map/EcosystemMap.astro";
import PassportMap from "../../../components/cvt-map/PassportMap.astro";
import VisionMap from "../../../components/cvt-map/VisionMap.astro";
import { cvtAppUrl } from "../../../lib/nav";

const sections = [
  { id: "user-layer", label: "User layer" },
  { id: "ecosystem", label: "Ecosystem" },
  { id: "trust-passport", label: "Trust Passport" },
  { id: "vision", label: "Vision" },
];
---

<CvtLayout title="The CVT Map — Connected Verification Trust" description="Visual map of CVT — from WhatsApp lookup to mobility reputation infrastructure for Africa.">
  <section class="section-band border-b border-hairline">
    <p class="eyebrow-mono">The CVT Map</p>
    <h1 class="display-xl mt-4 max-w-3xl">How a plate lookup becomes trust infrastructure</h1>
    <p class="map-lead mt-5">
      One page to see the user experience, the ecosystem, the Trust Passport, and the long-term vision — from WhatsApp to opportunities across Africa.
    </p>
    <nav class="mt-8 flex flex-wrap gap-2">
      {sections.map((s) => (
        <a href={`#${s.id}`} class="anchor-pill">{s.label}</a>
      ))}
    </nav>
  </section>

  <div class="mx-auto max-w-6xl space-y-24 px-4 py-16 sm:px-6 sm:py-20">
    <UserLayer />
    <EcosystemMap />
    <PassportMap />
    <VisionMap />

    <section class="card-soft px-6 py-10 text-center sm:px-10">
      <h2 class="display-md">Implementation roadmap</h2>
      <p class="map-lead mx-auto mt-3">Eight phases — from vehicle verification to financial inclusion. What exists today, what comes next, and why it matters.</p>
      <a href="/cvt/roadmap" class="btn-primary mt-6">View the full roadmap →</a>
    </section>
  </div>

  <section class="section-band border-t border-hairline bg-canvas-soft/30">
    <div class="flex flex-col items-start justify-between gap-6 sm:flex-row sm:items-center">
      <div>
        <p class="text-lg font-semibold text-ink-strong">Explore further</p>
        <p class="mt-1 text-sm text-mute">Docs, guides, and the live registry.</p>
      </div>
      <div class="flex flex-wrap gap-3">
        <a href="/cvt/vision" class="btn-outline !py-2.5 !text-sm">Vision essay</a>
        <a href="/cvt/guides" class="btn-outline !py-2.5 !text-sm">Guides</a>
        <a href={cvtAppUrl} target="_blank" rel="noopener" class="btn-primary !py-2.5 !text-sm">Live app ↗</a>
      </div>
    </div>
  </section>
</CvtLayout>
