---
import CvtLayout from "../../../layouts/CvtLayout.astro";
import ProjectMapStack from "../../../components/cvt-roadmap/ProjectMapStack.astro";
import LiveToday from "../../../components/cvt-roadmap/LiveToday.astro";
import PhaseCard from "../../../components/cvt-roadmap/PhaseCard.astro";
import { trustRoadmapPhases, siteLayers } from "../../../lib/cvt-roadmap";

const sections = [
  { id: "live-today", label: "Live today" },
  { id: "project-map", label: "Project map" },
  { id: "phases", label: "Phases" },
  { id: "audiences", label: "Audiences" },
];
---

<CvtLayout
  title="Building Trust Infrastructure for Mobility — CVT"
  description="Starting with vehicle verification and growing into portable trust profiles that reward good behaviour and unlock opportunity."
>
  <section class="section-band border-b border-hairline">
    <p class="eyebrow-mono">Implementation roadmap</p>
    <h1 class="display-xl mt-4 max-w-3xl">Building trust infrastructure for mobility</h1>
    <p class="map-lead mt-5">
      Starting with vehicle verification and growing into portable trust profiles that reward good behaviour and unlock opportunity.
    </p>

    <div class="mt-10 flex flex-wrap items-center gap-2 text-sm">
      {siteLayers.map((layer, i) => (
        <>
          {i > 0 && <span class="text-mute" aria-hidden="true">→</span>}
          <a
            href={layer.href}
            class:list={[
              "anchor-pill",
              layer.href === "/cvt/roadmap" && "border-primary/40 bg-canvas-soft text-primary-soft",
            ]}
          >
            {layer.label}
          </a>
        </>
      ))}
    </div>

    <nav class="mt-6 flex flex-wrap gap-2">
      {sections.map((s) => (
        <a href={`#${s.id}`} class="anchor-pill">{s.label}</a>
      ))}
    </nav>
  </section>

  <div class="mx-auto max-w-6xl space-y-24 px-4 py-16 sm:px-6 sm:py-20">
    <LiveToday />
    <ProjectMapStack />

    <section class="map-section" id="phases">
      <p class="map-kicker">Phases</p>
      <h2 class="map-heading">Journey to trust infrastructure</h2>
      <p class="map-lead">Not a software backlog — a story of what exists, what comes next, and why each step matters.</p>
      <div class="mt-10 space-y-6">
        {trustRoadmapPhases.map((phase) => (
          <PhaseCard phase={phase} />
        ))}
      </div>
    </section>

    <section class="map-section" id="audiences">
      <p class="map-kicker">Two audiences</p>
      <h2 class="map-heading">Public story · Builder depth</h2>
      <div class="mt-10 grid gap-6 sm:grid-cols-2">
        <div class="card-soft">
          <h3 class="text-lg font-semibold text-ink-strong">Public</h3>
          <p class="mt-2 text-sm text-mute">Problem · Solution · Roadmap · Why it matters</p>
          <ul class="mt-4 space-y-2 text-sm text-body">
            <li><a href="/cvt" class="hover:text-primary-soft">CVT home</a></li>
            <li><a href="/cvt/map" class="hover:text-primary-soft">Project map</a></li>
            <li><a href="/cvt/vision" class="hover:text-primary-soft">Vision</a></li>
            <li><a href="/cvt/concepts" class="hover:text-primary-soft">Concepts</a></li>
          </ul>
        </div>
        <div class="card-soft">
          <h3 class="text-lg font-semibold text-ink-strong">Builders & partners</h3>
          <p class="mt-2 text-sm text-mute">Architecture · Policies · Specifications · API docs</p>
          <ul class="mt-4 space-y-2 text-sm text-body">
            <li><a href="/cvt/docs" class="hover:text-primary-soft">Technical documents</a></li>
            <li><a href="/cvt/guides" class="hover:text-primary-soft">Integration guides</a></li>
            <li><a href="/cvt/docs/trust-profile" class="hover:text-primary-soft">Trust Profile spec</a></li>
            <li><a href="/cvt/docs/trust-architecture-v1" class="hover:text-primary-soft">Architecture v1</a></li>
          </ul>
        </div>
      </div>
      <p class="mt-8 text-center text-sm text-mute">
        jasilab.net is a public lab notebook — ideas and documents evolve; the story stays understandable.
      </p>
    </section>
  </div>
</CvtLayout>
