---
import { getCollection } from "astro:content";
import CvtLayout from "../../../layouts/CvtLayout.astro";

const docs = (await getCollection("cvtDocs")).sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
---

<CvtLayout title="Documents — CVT">
  <section class="section-band max-w-3xl">
    <h1 class="display-lg">Technical documents</h1>
    <p class="mt-4 text-body">Specifications for builders and partners — synced from the CVT product repository. For the public-facing journey, see the <a href="/cvt/roadmap">implementation roadmap</a>.</p>
    <ul class="mt-10 divide-y divide-hairline rounded-md border border-hairline">
      {docs.map((doc) => (
        <li>
          <a href={`/cvt/docs/${doc.id}`} class="flex items-start justify-between gap-4 px-5 py-4 transition hover:bg-canvas-soft">
            <div>
              <p class="font-semibold text-ink-strong">{doc.data.title}</p>
              {doc.data.description && <p class="mt-1 text-sm text-mute">{doc.data.description}</p>}
            </div>
            {doc.data.version && <span class="shrink-0 text-xs text-primary">{doc.data.version}</span>}
          </a>
        </li>
      ))}
    </ul>
  </section>
</CvtLayout>
