---
import { getCollection } from "astro:content";
import CvtLayout from "../../../layouts/CvtLayout.astro";

const docs = (await getCollection("cvtDocs")).sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
---

<CvtLayout title="Documents — CVT">
  <div class="mx-auto max-w-3xl px-4 py-16 sm:px-6">
    <h1 class="font-display text-4xl font-semibold text-white">Technical documents</h1>
    <p class="mt-4 text-slate-400">Specifications for builders and partners — synced from the CVT product repository. For the public-facing journey, see the <a href="/cvt/roadmap" class="text-teal-400 hover:underline">implementation roadmap</a>.</p>
    <ul class="mt-10 divide-y divide-white/10 rounded-xl border border-white/10">
      {docs.map((doc) => (
        <li>
          <a href={`/cvt/docs/${doc.id}`} class="flex items-start justify-between gap-4 px-5 py-4 transition hover:bg-white/5">
            <div>
              <p class="font-medium text-white">{doc.data.title}</p>
              {doc.data.description && <p class="mt-1 text-sm text-slate-500">{doc.data.description}</p>}
            </div>
            {doc.data.version && <span class="shrink-0 text-xs text-teal-500">{doc.data.version}</span>}
          </a>
        </li>
      ))}
    </ul>
  </div>
</CvtLayout>

<style>.font-display { font-family: "Fraunces", Georgia, serif; }</style>
