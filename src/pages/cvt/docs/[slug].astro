---
import { getCollection, render } from "astro:content";
import CvtLayout from "../../../layouts/CvtLayout.astro";

export async function getStaticPaths() {
  const docs = await getCollection("cvtDocs");
  return docs.map((doc) => ({ params: { slug: doc.id }, props: { doc } }));
}

const { doc } = Astro.props;
const { Content } = await render(doc);
const allDocs = (await getCollection("cvtDocs")).sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
---

<CvtLayout title={`${doc.data.title} — CVT Docs`} description={doc.data.description}>
  <div class="mx-auto flex max-w-6xl flex-col gap-10 px-4 py-12 lg:flex-row lg:px-6">
    <aside class="lg:w-56 lg:shrink-0">
      <p class="eyebrow-mono !text-[11px] !tracking-[0.2em] text-mute">Documents</p>
      <nav class="mt-4 space-y-1">
        {allDocs.map((d) => (
          <a
            href={`/cvt/docs/${d.id}`}
            class:list={[
              "block rounded-sm px-3 py-2 text-sm",
              d.id === doc.id ? "nav-link-active" : "nav-link",
            ]}
          >
            {d.data.title}
          </a>
        ))}
      </nav>
    </aside>
    <article class="doc-panel min-w-0 flex-1">
      <header class="mb-8 border-b border-hairline pb-6">
        <a href="/cvt/docs" class="text-sm text-primary-deep hover:text-primary">← All documents</a>
        {doc.data.version && <p class="mt-2 text-xs font-semibold uppercase tracking-widest text-primary">{doc.data.version}</p>}
      </header>
      <div class="doc-content">
        <Content />
      </div>
    </article>
  </div>
</CvtLayout>
