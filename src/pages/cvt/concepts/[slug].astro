---
import { cvtPath } from "../../../lib/site";
import CvtLayout from "../../../layouts/CvtLayout.astro";
import { cvtConcepts } from "../../../lib/nav";

export function getStaticPaths() {
  return cvtConcepts.map((c) => ({ params: { slug: c.slug }, props: { concept: c } }));
}

const { concept } = Astro.props;
---

<CvtLayout title={`${concept.title} — CVT`}>
  <section class="section-band max-w-3xl">
    <a href={cvtPath("concepts")} class="btn-ghost !px-0 !py-0 !text-sm">← All concepts</a>
    <h1 class="display-lg mt-6">{concept.title}</h1>
    <p class="mt-6 text-lg text-body">{concept.summary}</p>
    <p class="mt-8 text-sm text-mute">For partner integrations and detailed policies, see the <a href={cvtPath("guides")}>guides</a> or contact <a href="mailto:hello@jasilab.net">hello@jasilab.net</a>.</p>
  </section>
</CvtLayout>
