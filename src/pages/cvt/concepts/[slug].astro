---
import CvtLayout from "../../../layouts/CvtLayout.astro";
import { cvtConcepts } from "../../../lib/nav";

export function getStaticPaths() {
  return cvtConcepts.map((c) => ({ params: { slug: c.slug }, props: { concept: c } }));
}

const { concept } = Astro.props;
---

<CvtLayout title={`${concept.title} — CVT`}>
  <section class="section-band max-w-3xl">
    <a href="/cvt/concepts" class="btn-ghost !px-0 !py-0 !text-sm">← All concepts</a>
    <h1 class="display-lg mt-6">{concept.title}</h1>
    <p class="mt-6 text-lg text-body">{concept.summary}</p>
    <p class="mt-8 text-sm text-mute">Detailed rules and implementation notes are in the <a href="/cvt/docs/trust-profile">Trust Profile</a> specification.</p>
  </section>
</CvtLayout>
