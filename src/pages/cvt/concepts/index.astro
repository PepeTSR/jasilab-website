---
import CvtLayout from "../../../layouts/CvtLayout.astro";
import { cvtConcepts } from "../../../lib/nav";
---

<CvtLayout title="Concepts — CVT">
  <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6">
    <h1 class="font-display text-4xl font-semibold text-white">Concepts</h1>
    <p class="mt-4 max-w-2xl text-slate-400">Plain-language explainers. Full specifications live in <a href="/cvt/docs" class="text-teal-400 hover:underline">Documents</a>.</p>
    <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {cvtConcepts.map((c) => (
        <a href={`/cvt/concepts/${c.slug}`} class="rounded-xl border border-white/10 bg-white/5 p-5 transition hover:border-teal-700/50 hover:bg-white/[0.07]">
          <h2 class="font-semibold text-white">{c.title}</h2>
          <p class="mt-2 text-sm text-slate-400">{c.summary}</p>
        </a>
      ))}
    </div>
  </div>
</CvtLayout>

<style>.font-display { font-family: "Fraunces", Georgia, serif; }</style>
