---
import CvtLayout from "../../../layouts/CvtLayout.astro";
---

<CvtLayout title="Blog — CVT">
  <div class="mx-auto max-w-3xl px-4 py-16 sm:px-6">
    <h1 class="font-display text-4xl font-semibold text-white">CVT Blog</h1>
    <p class="mt-4 text-slate-400">Articles on trust infrastructure, insurance, and mobility.</p>
    <ul class="mt-10 space-y-4 text-slate-500">
      <li class="rounded-lg border border-dashed border-white/20 p-4">Why Africa needs trust infrastructure</li>
      <li class="rounded-lg border border-dashed border-white/20 p-4">Insurance before credit</li>
      <li class="rounded-lg border border-dashed border-white/20 p-4">Why complaints should not destroy reputations</li>
    </ul>
  </div>
</CvtLayout>

<style>.font-display { font-family: "Fraunces", Georgia, serif; }</style>
