---
import JasiLabLayout from "../layouts/JasiLabLayout.astro";
---

<JasiLabLayout title="About — JasiLab">
  <section class="section-band max-w-3xl">
    <h1 class="display-lg">About JasiLab</h1>
    <div class="mt-6 space-y-4 text-body leading-relaxed">
      <p>JasiLab is a research and product lab focused on trust infrastructure — systems that help informal economies access insurance, employment, and accountability without relying on credit bureaus or permanent punishment.</p>
      <p>Our first product, CVT (Connected Verification Terminal), is a public trust platform — starting with commercial transport in Uganda and expanding to trusted identities for service providers across the informal and formal economy.</p>
    </div>
  </section>
</JasiLabLayout>
