---
import JasiLabLayout from "../layouts/JasiLabLayout.astro";
---

<JasiLabLayout title="About — JasiLab">
  <div class="mx-auto max-w-3xl px-4 py-16 sm:px-6">
    <h1 class="font-display text-4xl font-semibold text-slate-900">About JasiLab</h1>
    <p class="mt-6 text-lg text-slate-600">
      JasiLab is a research and product lab focused on trust infrastructure — systems that help informal economies access insurance, employment, and accountability without relying on credit bureaus or permanent punishment.
    </p>
    <p class="mt-4 text-slate-600">
      Our first product, CVT (Connected Verification Trust), is a registry and trust platform for commercial mobility in Uganda — boda riders today, multi-category registry tomorrow.
    </p>
  </div>
</JasiLabLayout>

<style>.font-display { font-family: "Fraunces", Georgia, serif; }</style>
