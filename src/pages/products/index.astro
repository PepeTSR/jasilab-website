---
import JasiLabLayout from "../../layouts/JasiLabLayout.astro";
import { productLinks } from "../../lib/nav";
---

<JasiLabLayout title="Products — JasiLab">
  <section class="section-band">
    <h1 class="display-lg">Products</h1>
    <p class="mt-4 max-w-2xl text-body">Systems built from JasiLab research — each product has its own documentation and roadmap.</p>
    <div class="mt-10 grid gap-4 sm:grid-cols-2">
      {productLinks.map((p) => (
        <a href={p.href} class="card-feature group block">
          <h2 class="text-2xl font-semibold text-ink-strong group-hover:text-primary-soft">{p.label}</h2>
          <p class="mt-3 text-body">{p.tagline}</p>
        </a>
      ))}
    </div>
  </section>
</JasiLabLayout>
