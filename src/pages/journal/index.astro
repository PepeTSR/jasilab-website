---
import JasiLabLayout from "../../layouts/JasiLabLayout.astro";
---

<JasiLabLayout title="Journal — JasiLab">
  <div class="mx-auto max-w-3xl px-4 py-16 sm:px-6">
    <h1 class="font-display text-4xl font-semibold text-slate-900">Journal</h1>
    <p class="mt-6 text-slate-600">Essays and updates from JasiLab. CVT-specific articles live in the <a href="/cvt/blog" class="text-teal-700 hover:underline">CVT blog</a>.</p>
    <p class="mt-8 rounded-xl border border-dashed border-slate-300 p-8 text-center text-sm text-slate-500">First posts coming soon.</p>
  </div>
</JasiLabLayout>

<style>.font-display { font-family: "Fraunces", Georgia, serif; }</style>
