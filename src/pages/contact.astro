---
import JasiLabLayout from "../layouts/JasiLabLayout.astro";
---

<JasiLabLayout title="Contact — JasiLab">
  <div class="mx-auto max-w-3xl px-4 py-16 sm:px-6">
    <h1 class="font-display text-4xl font-semibold text-slate-900">Contact</h1>
    <p class="mt-6 text-slate-600">Reach JasiLab for research collaboration, CVT partnerships, or general enquiries.</p>
    <p class="mt-4"><a href="mailto:hello@jasilab.net" class="text-lg text-teal-700 hover:underline">hello@jasilab.net</a></p>
  </div>
</JasiLabLayout>

<style>.font-display { font-family: "Fraunces", Georgia, serif; }</style>
