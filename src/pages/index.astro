---
import JasiLabLayout from "../layouts/JasiLabLayout.astro";
import { productLinks } from "../lib/nav";
import { isCvtRootSite } from "../lib/site";

const isDevCvtRoot = import.meta.env.DEV && isCvtRootSite;
---

{isDevCvtRoot && (
  <script is:inline>
    if (location.pathname === "/" || location.pathname === "") {
      location.replace("/cvt/" + location.hash + location.search);
    }
  </script>
)}

<JasiLabLayout title="JasiLab — Research & Products" description="JasiLab builds trust infrastructure for informal economies.">
  <section class="section-band border-b border-hairline">
    <p class="eyebrow-mono">Research · Products · Journal</p>
    <h1 class="display-xl mt-4 max-w-3xl">
      Trust infrastructure for economies that run on relationships, not records.
    </h1>
    <p class="lead mt-6 max-w-2xl">
      JasiLab researches and builds systems that turn verified facts into portable trust — starting with mobility in Uganda.
    </p>
    <div class="mt-10 flex flex-wrap gap-3">
      <a href="/cvt" class="btn-primary">Explore CVT</a>
      <a href="/research" class="btn-outline">Research</a>
    </div>
  </section>

  <section class="section-band section-divider">
    <h2 class="display-md">Products</h2>
    <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {productLinks.map((p) => (
        <a href={p.href} class="card-feature group block">
          <h3 class="text-xl font-semibold text-ink-strong group-hover:text-primary-soft">{p.label}</h3>
          <p class="mt-2 text-sm text-body">{p.tagline}</p>
        </a>
      ))}
    </div>
  </section>
</JasiLabLayout>
